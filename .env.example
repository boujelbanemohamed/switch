# JWT secret — generate with: openssl rand -base64 64
JWT_SECRET=

# PostgreSQL
POSTGRES_PASSWORD=switch_pass

# PAN hashing key (HMAC-SHA256) — generate with: openssl rand -base64 32
PAN_HASH_KEY=

# PIN encryption key (AES-256)
PIN_ENCRYPTION_KEY=

# PCI encryption key (AES-256) — generate with: openssl rand -base64 32
PCI_ENCRYPTION_KEY=

# CORS allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Notifications (optional)
NOTIFICATIONS_ENABLED=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
